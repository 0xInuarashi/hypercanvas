{
  "name": "hypercanvas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun server/pty-server.ts & PTY=$!; trap 'kill $PTY 2>/dev/null' EXIT; vite",
    "dev:public": "HOST=0.0.0.0 bun server/pty-server.ts & PTY=$!; trap 'kill $PTY 2>/dev/null' EXIT; HOST=0.0.0.0 vite",
    "dev:ui": "vite",
    "dev:pty": "bun server/pty-server.ts",
    "build": "svelte-check --tsconfig ./tsconfig.app.json && vite build",
    "build:bin": "bun build --compile server/pty-server.ts --outfile hypercanvas",
    "build:all": "bun run build && bun run build:bin",
    "start": "bun server/pty-server.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.app.json",
    "clean": "rm -rf dist node_modules/.tmp hypercanvas"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "qrcode": "^1.5.4",
    "shiki": "^4.0.2",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/bun": "^1.2.0",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.5",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
